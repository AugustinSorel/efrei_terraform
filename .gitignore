# Local .terraform directories
**/.terraform/*

# .tfstate files
# These contain sensitive information and should be stored in a remote backend (S3, GCS, etc.)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data-specific to your deployments.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local adjustments
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include override files for sharing internal builds (optional)
# !example_override.tf

# Include build-related files
.terraform.lock.hcl

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terragrunt dependency files (if using Terragrunt)
.terragrunt-cache